{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_cf_gateway_openrouter_url": {
        "type": "string"
      },
      "agent_cf_gateway_token": {
        "type": "string",
        "secret": true
      },
      "agent_crm_b2b_db_path": {
        "type": "string"
      },
      "agent_crm_b2c_db_path": {
        "type": "string"
      },
      "agent_crm_db_path": {
        "type": "string"
      },
      "agent_crm_org_type": {
        "type": "string"
      },
      "agent_crm_query_row_limit": {
        "type": "integer"
      },
      "agent_llm_model": {
        "type": "string"
      },
      "agent_log_level": {
        "type": "string"
      },
      "agent_max_turns": {
        "type": "integer"
      },
      "agent_model_timeout_seconds": {
        "type": "integer"
      },
      "agent_model_user_agent": {
        "type": "string"
      },
      "agent_openrouter_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_temperature": {
        "type": "number"
      },
      "green_nebius_api_key": {
        "type": "string",
        "secret": true
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_openai_api_key",
      "green_nebius_api_key",
      "agent_cf_gateway_openrouter_url",
      "agent_cf_gateway_token",
      "agent_openrouter_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "task_limit": 3,
          "drift_level": "none",
          "rot_level": "none",
          "max_steps": 7,
          "timeout": 300,
          "org_type": "b2c"
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/DeoGaze-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "nebius_api_key": "${config.green_nebius_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/Arcobalneo/crm-purple-agent-a2a/refs/heads/main/amber-manifest.json5",
      "config": {
        "cf_gateway_openrouter_url": "${config.agent_cf_gateway_openrouter_url}",
        "cf_gateway_token": "${config.agent_cf_gateway_token}",
        "crm_b2b_db_path": "${config.agent_crm_b2b_db_path}",
        "crm_b2c_db_path": "${config.agent_crm_b2c_db_path}",
        "crm_db_path": "${config.agent_crm_db_path}",
        "crm_org_type": "${config.agent_crm_org_type}",
        "crm_query_row_limit": "${config.agent_crm_query_row_limit}",
        "llm_model": "${config.agent_llm_model}",
        "log_level": "${config.agent_log_level}",
        "max_turns": "${config.agent_max_turns}",
        "model_timeout_seconds": "${config.agent_model_timeout_seconds}",
        "model_user_agent": "${config.agent_model_user_agent}",
        "openrouter_api_key": "${config.agent_openrouter_api_key}",
        "temperature": "${config.agent_temperature}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca155-47bc-7863-bbc5-4747c4c5975a",
      "agent": "019cfa46-ecc6-7ca1-a558-021d96c5c2f1"
    }
  }
}