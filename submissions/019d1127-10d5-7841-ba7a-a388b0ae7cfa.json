{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_llm_cheap_base_url": {
        "type": "string"
      },
      "agent_llm_cheap_model": {
        "type": "string"
      },
      "agent_llm_primary_base_url": {
        "type": "string"
      },
      "agent_llm_primary_model": {
        "type": "string"
      },
      "agent_openai_cheap_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_openai_primary_api_key": {
        "type": "string",
        "secret": true
      },
      "green_nebius_api_key": {
        "type": "string",
        "secret": true
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_openai_api_key",
      "green_nebius_api_key",
      "agent_openai_primary_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "task_limit": 20,
          "drift_level": "none",
          "rot_level": "none",
          "max_steps": 7,
          "timeout": 300,
          "org_type": "b2c"
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/DeoGaze-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "nebius_api_key": "${config.green_nebius_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/MadGAA-Lab/CRM-Agent-Phase2_dev/refs/heads/main/amber-manifest.json5",
      "config": {
        "llm_cheap_base_url": "${config.agent_llm_cheap_base_url}",
        "llm_cheap_model": "${config.agent_llm_cheap_model}",
        "llm_primary_base_url": "${config.agent_llm_primary_base_url}",
        "llm_primary_model": "${config.agent_llm_primary_model}",
        "openai_cheap_api_key": "${config.agent_openai_cheap_api_key}",
        "openai_primary_api_key": "${config.agent_openai_primary_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca155-47bc-7863-bbc5-4747c4c5975a",
      "agent": "019d0747-e8ee-75e2-a899-3a0ac4d0afc8"
    }
  }
}