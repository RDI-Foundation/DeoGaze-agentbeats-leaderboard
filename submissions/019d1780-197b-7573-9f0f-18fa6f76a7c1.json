{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "green_nebius_api_key": {
        "type": "string",
        "secret": true
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "solstice_agent_agentbeats_llm_model": {
        "type": "string"
      },
      "solstice_agent_anthropic_api_key": {
        "type": "string",
        "secret": true
      },
      "solstice_agent_google_api_key": {
        "type": "string",
        "secret": true
      },
      "solstice_agent_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "solstice_agent_pinecone_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_openai_api_key",
      "green_nebius_api_key",
      "solstice_agent_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "task_limit": 3,
          "drift_level": "none",
          "rot_level": "none",
          "max_steps": 7,
          "timeout": 300,
          "org_type": "b2c"
        },
        "participant_roles": {
          "green": "green",
          "purple1": "solstice_agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/DeoGaze-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "nebius_api_key": "${config.green_nebius_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "solstice_agent": {
      "manifest": "https://raw.githubusercontent.com/Solasticeaistudio/solstice-agentbeats/master/amber-manifest-bizprocess.json5",
      "config": {
        "agentbeats_llm_model": "${config.solstice_agent_agentbeats_llm_model}",
        "anthropic_api_key": "${config.solstice_agent_anthropic_api_key}",
        "google_api_key": "${config.solstice_agent_google_api_key}",
        "openai_api_key": "${config.solstice_agent_openai_api_key}",
        "pinecone_api_key": "${config.solstice_agent_pinecone_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#solstice_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca155-47bc-7863-bbc5-4747c4c5975a",
      "solstice_agent": "019d1716-1a50-7b43-b718-746eb939017b"
    }
  }
}