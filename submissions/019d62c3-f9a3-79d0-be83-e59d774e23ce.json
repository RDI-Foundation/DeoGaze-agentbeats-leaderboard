{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_anthropic_api_key": {
        "type": "string",
        "secret": true
      },
      "green_nebius_api_key": {
        "type": "string",
        "secret": true
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_openai_api_key",
      "green_nebius_api_key",
      "agent_anthropic_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {},
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/DeoGaze-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "nebius_api_key": "${config.green_nebius_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/cashman2100/crm_agent/main/amber-manifest.json5",
      "config": {
        "anthropic_api_key": "${config.agent_anthropic_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca155-47bc-7863-bbc5-4747c4c5975a",
      "agent": "019d5db4-67eb-7a40-8103-25e806c6037c"
    }
  }
}